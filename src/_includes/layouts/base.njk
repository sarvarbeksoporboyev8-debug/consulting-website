<!DOCTYPE html>
<html lang="{{ lang.htmlLang | default('en') }}" dir="{{ lang.dir | default('ltr') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- if description %}
  <meta name="description" content="{{ description }}">
  {%- endif %}
  <title>{{ title }}</title>
  <link rel="icon" href="{{ langRoot }}favicon.svg" type="image/svg+xml">
  <link rel="icon" href="{{ langRoot }}favicon.ico" sizes="any">
  {%- if description %}
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="{{ ogType | default('website') }}">
  <meta property="og:image" content="{{ site.shared.domain }}/favicon.svg">
  <meta property="og:url" content="{{ site.shared.domain }}/{{ L }}/{{ currentPage | default('index.html') }}">
  {%- endif %}
  <link rel="stylesheet" href="{{ langRoot }}css/fonts.css">
  <link rel="stylesheet" href="{{ langRoot }}css/site.css">
  {%- if pageCss %}
  <link rel="stylesheet" href="{{ langRoot }}{{ pageCss }}">
  {%- endif %}
  <script src="{{ langRoot }}js/site.js" defer></script>
</head>
<body>
  {% include "partials/header.njk" %}

  <main id="main-content">
{{ content | safe }}
  </main>
  {%- if not noFooter %}
  {% include "partials/footer.njk" %}
  {%- endif %}
</body>
</html>
