---
layout: layouts/base.njk
---
    <section class="page-hero">
      <div class="page-hero-inner">
        <h1>{{ heroTitle }}</h1>
        <p>{{ heroSubtitle | default(t.hero_subtitle) }}</p>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/{{ L }}/index.html">{{ t.breadcrumb_home | default("Home") }}</a>
          {%- for crumb in breadcrumbs %}
          <span>/</span>
          {%- if crumb.url %}
          <a href="/{{ L }}/{{ crumb.url }}">{{ crumb.label }}</a>
          {%- else %}
          <span>{{ crumb.label }}</span>
          {%- endif %}
          {%- endfor %}
        </nav>
      </div>
    </section>

{{ content | safe }}
