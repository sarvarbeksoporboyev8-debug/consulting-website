    <footer>
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <a href="/{{ L }}/index.html" class="logo">{{ site[L].name }}</a>
            <p>{{ site[L].tagline }}</p>
            <form class="newsletter-form" action="https://formsubmit.co/ajax/Info@ukud-uzb.uz" method="POST" data-form novalidate>
              <input type="hidden" name="_subject" value="Newsletter subscription - grant-consulting.uz">
              <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off">
              <label class="sr-only" for="newsletter-email">Email</label>
              <div class="footer-email">
                <input type="email" id="newsletter-email" name="email" placeholder="{{ t.footer_email_placeholder }}" required>
                <button type="submit" class="btn-primary">{{ t.btn_subscribe }}</button>
              </div>
              <p class="form-status" data-form-status data-msg-success="{{ t.newsletter_success }}" data-msg-error="{{ t.form_error }}" aria-live="polite"></p>
            </form>
          </div>
          <div class="footer-col">
            <h4>{{ t.footer_services }}</h4>
            <ul>
              {%- for svc in services[L] %}
              {%- if loop.index <= 4 %}
              <li><a href="/{{ L }}/{{ svc.link }}">{{ svc.title }}</a></li>
              {%- endif %}
              {%- endfor %}
            </ul>
          </div>
          <div class="footer-col">
            <h4>{{ t.footer_about }}</h4>
            <ul>
              <li><a href="/{{ L }}/about.html#mission-panel">{{ t.footer_mission }}</a></li>
              <li><a href="/{{ L }}/about.html#vision-panel">{{ t.footer_vision }}</a></li>
              <li><a href="/{{ L }}/contact.html">{{ t.footer_talk }}</a></li>
            </ul>
          </div>
          <div class="footer-col footer-contact">
            <h4>{{ t.footer_contact }}</h4>
            <p>{{ site.shared["address_" + L] | default(site.shared.address_en) }}</p>
            <p><a href="{{ site.shared.phoneHref }}">{{ site.shared.phone }}</a></p>
            <p><a href="{{ site.shared.phone2Href }}">{{ site.shared.phone2 }}</a></p>
            <p><a href="mailto:{{ site.shared.email }}">{{ site.shared.email }}</a></p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {{ site[L].year }} {{ site[L].name }}. {{ t.footer_rights }}</p>
        </div>
      </div>
    </footer>
