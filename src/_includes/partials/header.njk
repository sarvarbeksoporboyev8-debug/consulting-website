  <a class="skip-link" href="#main-content">Skip to content</a>
  <header class="site-header">
    <div class="header-inner">
      <a href="/{{ L }}/index.html" class="logo">{{ site[L].name | default("GRANT CONSULTING") }}</a>
      <button type="button" class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation">
        <span class="nav-toggle-bar"></span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="Primary">
        <div class="nav-links">
          <a href="/{{ L }}/index.html"{% if navKey == "Home" %} aria-current="page"{% endif %}>{{ t.nav_home }}</a>

          <div class="nav-dropdown">
            <a href="/{{ L }}/about.html"{% if navKey == "About" %} aria-current="page"{% endif %} class="nav-dropdown-toggle">{{ t.nav_about }} <span class="dropdown-arrow"></span></a>
            <div class="nav-dropdown-menu">
              <a href="/{{ L }}/about.html#mission-panel">{{ t.footer_mission }}</a>
              <a href="/{{ L }}/about.html#vision-panel">{{ t.footer_vision }}</a>
              <a href="/{{ L }}/about.html#team-section">{{ t.nav_team }}</a>
              <a href="/{{ L }}/faq.html">FAQ</a>
            </div>
          </div>

          <div class="nav-dropdown">
            <a href="/{{ L }}/services.html"{% if navKey == "Services" %} aria-current="page"{% endif %} class="nav-dropdown-toggle">{{ t.nav_services }} <span class="dropdown-arrow"></span></a>
            <div class="nav-dropdown-menu">
              {%- for svc in services[L] %}
              <a href="/{{ L }}/{{ svc.link }}">{{ svc.title }}</a>
              {%- endfor %}
            </div>
          </div>

          <div class="nav-dropdown">
            <a href="/{{ L }}/blog.html"{% if navKey == "Blog" %} aria-current="page"{% endif %} class="nav-dropdown-toggle">{{ t.nav_blog }} <span class="dropdown-arrow"></span></a>
            <div class="nav-dropdown-menu">
              {%- for post in blog[L] %}
              <a href="/{{ L }}/{{ post.link }}">{{ post.title }}</a>
              {%- endfor %}
            </div>
          </div>

          <a href="/{{ L }}/events.html"{% if navKey == "Events" %} aria-current="page"{% endif %}>{{ t.nav_events }}</a>
          <a href="/{{ L }}/gallery.html"{% if navKey == "Gallery" %} aria-current="page"{% endif %}>{{ t.nav_gallery }}</a>
          <a href="/{{ L }}/contact.html"{% if navKey == "Contact" %} aria-current="page"{% endif %}>{{ t.nav_contact }}</a>
        </div>
        <div class="nav-actions">
          <div class="lang-switcher">
            {%- for l in languages %}
            <a href="/{{ l.code }}/{{ currentPage | default('index.html') }}"{% if l.code == L %} class="active" aria-current="true"{% endif %} title="{{ l.name }}">{{ l.short }}</a>
            {%- endfor %}
          </div>
          <a href="/{{ L }}/contact.html#contact-form" class="btn-signup">{{ t.btn_free_consultation }}</a>
        </div>
      </nav>
    </div>
  </header>
