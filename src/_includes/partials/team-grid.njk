      <div class="team-grid">
        {%- for member in team[L] %}
        <div class="team-card">
          <div class="photo">
            {%- if member.photo %}
            <img src="{{ langRoot }}{{ member.photo }}" alt="{{ member.name }}" loading="lazy" width="300" height="300">
            {%- endif %}
          </div>
          <h3>{{ member.name }}</h3>
          <div class="role">{{ member.role }}</div>
          <div class="socials">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </div>
        </div>
        {%- endfor %}
      </div>
