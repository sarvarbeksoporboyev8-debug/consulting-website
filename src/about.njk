---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/about.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/about.css",
  navKey: "About",
  extraFonts: "",
  currentPage: "about.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.ui[L]||data.ui.en).page_about_title + " - Grant Consulting"; },
    description: function(data) { return (data.site[data.lang.code]||data.site.en).tagline; },
    heroTitle: function(data) { return (data.ui[data.lang.code]||data.ui.en).page_about_hero; },
    breadcrumbs: function(data) { return [{ label: (data.ui[data.lang.code]||data.ui.en).page_about_hero }]; }
  }
}
---
    <section class="lead-section">
      <div class="lead-grid">
        <div class="lead-content">
          <h2>{{ t.about_lead_title | safe }}</h2>
          <p class="intro">{{ t.about_lead_subtitle }}</p>
          <div data-tabs>
          <div class="lead-tabs" role="tablist">
            <button type="button" role="tab" id="tab-mission" class="active" aria-selected="true" data-tab-target="mission-panel">{{ t.about_tab_mission }}</button>
            <button type="button" role="tab" id="tab-vision" aria-selected="false" tabindex="-1" data-tab-target="vision-panel">{{ t.about_tab_vision }}</button>
            <button type="button" role="tab" id="tab-values" aria-selected="false" tabindex="-1" data-tab-target="value-panel">{{ t.about_tab_values }}</button>
          </div>
          <div class="tab-content">
            <div id="mission-panel" role="tabpanel" aria-labelledby="tab-mission" class="is-active" data-tab-panel>
              {{ t.about_mission_text | safe }}
            </div>
            <div id="vision-panel" role="tabpanel" aria-labelledby="tab-vision" data-tab-panel hidden>
              {{ t.about_vision_text | safe }}
            </div>
            <div id="value-panel" role="tabpanel" aria-labelledby="tab-values" data-tab-panel hidden>
              {{ t.about_values_text | safe }}
            </div>
          </div>
          </div>
        </div>
        <div class="lead-visual">
          <div class="lead-image" style="background-image:url('{{ langRoot }}img/about-lead.jpg');" aria-hidden="true"></div>
          <div class="lead-card">
            <div class="label">{{ t.about_countries_label }}</div>
            <div class="count">{{ t.about_countries_count }}</div>
            <hr>
            {%- for uni in universities[L] %}
            {%- if loop.index <= 3 %}
            <div class="item">{{ uni.country }}</div>
            {%- endif %}
            {%- endfor %}
          </div>
        </div>
      </div>
    </section>

    {% include "partials/features.njk" %}

    <section class="team-section" id="team-section">
      <div class="team-inner">
        <div class="section-header" style="text-align:center;margin-bottom:48px;">
          <h2>{{ t.team_title }}</h2>
          <p>{{ t.team_subtitle }}</p>
        </div>
        <div class="team-grid">
          {%- for member in team[L] %}
          <div class="team-card">
            <div class="team-photo">
              <img src="{{ langRoot }}img/team/{{ member.photo }}" alt="{{ member.name }}" loading="lazy">
            </div>
            <h3 class="team-name">{{ member.name }}</h3>
            <p class="team-role">{{ member.role }}</p>
          </div>
          {%- endfor %}
        </div>
      </div>
    </section>

    {% set formPrefix = "about" %}
    {% include "partials/form-faq-section.njk" %}

    {% include "partials/cta-simple.njk" %}
