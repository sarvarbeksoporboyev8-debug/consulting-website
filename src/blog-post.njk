---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/blog-post.html"; },
  layout: "layouts/base.njk",
  pageCss: "css/blog-post.css",
  navKey: "Blog",
  ogType: "article",
  extraFonts: "&family=Merriweather:wght@700",
  currentPage: "blog-post.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.blog[L]||data.blog.en)[0].title + " - Grant Consulting"; },
    description: function(data) { var L = data.lang.code; return (data.blog[L]||data.blog.en)[0].excerpt; }
  }
}
---
    <section class="page-hero">
      <div class="page-hero-inner">
        <h1>{{ blog[L][0].title }}</h1>
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/{{ L }}/index.html">{{ t.breadcrumb_home }}</a>
          <span>/</span>
          <a href="/{{ L }}/blog.html">{{ t.nav_blog }}</a>
          <span>/</span>
          <span>{{ blog[L][0].title }}</span>
        </nav>
      </div>
    </section>

    <div class="main-wrap">
      {% include "partials/blog-sidebar.njk" %}

      <div class="post-main">
        <article class="post-content">
          <div class="post-featured"></div>
          <div class="post-body">
            <div class="post-meta">
              <span>{{ blog[L][0].author }}</span>
              <span>{{ blog[L][0].date }}</span>
            </div>
            <h2>{{ blog[L][0].title }}</h2>
            <p class="lead">{{ blog[L][0].excerpt }}</p>
            <div class="share-row">
              <span>Share:</span>
              <div class="share-icons">
                <a href="{{ site.shared.instagram }}" aria-label="Instagram">IG</a>
                <a href="{{ site.shared.telegram }}" aria-label="Telegram">TG</a>
              </div>
            </div>
            <nav class="post-nav" aria-label="Post navigation">
              <div class="prev">
                <a href="/{{ L }}/blog.html">{{ t.nav_blog }}</a>
              </div>
            </nav>
          </div>
        </article>
      </div>
    </div>
