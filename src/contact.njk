---
layout: layouts/page.njk
title: "Contact Us - Grant Consulting"
description: "Contact Grant Consulting to discuss your study abroad plans. Free consultation available."
pageCss: "css/contact.css"
navKey: "Contact"
extraFonts: "&family=Merriweather:wght@700"
heroTitle: "Contact Us"
breadcrumbs:
  - label: "Contact"
---
    <div class="contact-wrap">
      <div class="contact-details-card">
        <div class="card-head">
          <h2>Contact Details</h2>
        </div>
        <div class="card-body">
          <h3>Office Address</h3>
          <div class="address">
            <span class="icon" aria-hidden="true"></span>
            <p>{{ site.address }}</p>
          </div>
          <div class="contact-info">
            <h3>Contact Info</h3>
            <div class="contact-row">
              <span class="icon icon-sm" aria-hidden="true"></span>
              <p>{{ site.phone }}</p>
            </div>
            {%- if site.phone2 %}
            <div class="contact-row">
              <span class="icon icon-sm" aria-hidden="true"></span>
              <p>{{ site.phone2 }}</p>
            </div>
            {%- endif %}
            <div class="contact-row">
              <span class="icon icon-sm" aria-hidden="true"></span>
              <p>{{ site.email }}</p>
            </div>
            {%- if site.instagram %}
            <div class="contact-row">
              <span class="icon icon-sm" aria-hidden="true"></span>
              <p>Instagram: {{ site.instagram }}</p>
            </div>
            {%- endif %}
          </div>
        </div>
      </div>

      <div class="contact-form-card" id="contact-form">
        <form action="#" method="post" class="stacked-form" data-form novalidate>
          <div class="form-group">
            <label for="contact-name">Name*</label>
            <input type="text" id="contact-name" name="name" placeholder="Enter your name" required>
          </div>
          <div class="form-group">
            <label for="contact-email">Email*</label>
            <input type="email" id="contact-email" name="email" placeholder="Enter your email address" required>
          </div>
          <div class="form-group">
            <label for="contact-message">Tell us about your goals*</label>
            <textarea id="contact-message" name="message" placeholder="What country and program are you interested in? What is your current IELTS score?" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn-send">Send Message</button>
          <p class="form-status" data-form-status aria-live="polite"></p>
        </form>
      </div>
    </div>

    <section class="map-section" aria-label="Map">
      <div class="map-placeholder" aria-hidden="true"></div>
    </section>

    <section class="cta-section">
      <div class="cta-inner">
        <h2>Ready to start your study abroad journey?</h2>
        <a href="contact.html#contact-form" class="btn-book">
          <span>Book a <strong>Free</strong> Consultation</span>
          <span class="icon" aria-hidden="true"></span>
        </a>
      </div>
    </section>
