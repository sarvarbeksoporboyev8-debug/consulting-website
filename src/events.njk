---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/events.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/blog.css",
  navKey: "Events",
  extraFonts: "",
  currentPage: "events.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.ui[L]||data.ui.en).nav_events + " - Grant Consulting"; },
    description: function(data) { return (data.ui[data.lang.code]||data.ui.en).events_subtitle; },
    heroTitle: function(data) { return (data.ui[data.lang.code]||data.ui.en).nav_events; },
    breadcrumbs: function(data) { return [{ label: (data.ui[data.lang.code]||data.ui.en).nav_events }]; }
  }
}
---
    <div class="blog-content" style="max-width:900px;margin:0 auto;padding:48px 24px;">
      <div class="section-header" style="text-align:center;margin-bottom:48px;">
        <h2>{{ t.events_title }}</h2>
        <p>{{ t.events_subtitle }}</p>
      </div>
      <p style="text-align:center;color:var(--gray-500);font-size:1.125rem;">{{ t.events_coming_soon }}</p>
    </div>

    {% include "partials/cta-simple.njk" %}
