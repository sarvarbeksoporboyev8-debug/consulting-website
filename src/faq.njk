---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/faq.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/faq.css",
  extraFonts: "&family=Merriweather:wght@700",
  currentPage: "faq.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.ui[L]||data.ui.en).page_faq_title + " - Grant Consulting"; },
    description: function(data) { return (data.ui[data.lang.code]||data.ui.en).page_faq_title; },
    heroTitle: function(data) { return (data.ui[data.lang.code]||data.ui.en).page_faq_hero; },
    breadcrumbs: function(data) { return [{ label: (data.ui[data.lang.code]||data.ui.en).page_faq_hero }]; }
  }
}
---
    <div class="faq-wrap">
      <aside class="faq-sidebar">
        <div class="sidebar-head">
          <h2>{{ t.faq_sidebar_title }}</h2>
        </div>
        <div class="sidebar-body">
          <nav aria-label="FAQ categories">
            {%- for cat in t.faq_categories %}
            <a href="#faq"{% if loop.first %} class="active"{% endif %}>{{ cat }}</a>
            {%- endfor %}
          </nav>
        </div>
      </aside>

      <div class="faq-content" id="faq">
        <ul class="faq-list">
          {%- for item in faq[L].full %}
          <li class="faq-item{% if loop.first %} is-open{% endif %}">
            <button type="button" aria-expanded="{{ 'true' if loop.first else 'false' }}" aria-controls="faq-{{ loop.index }}" id="faq-q{{ loop.index }}">
              {{ item.question }}
              <span class="faq-toggle" aria-hidden="true"></span>
            </button>
            <div class="faq-answer" id="faq-{{ loop.index }}" role="region" aria-labelledby="faq-q{{ loop.index }}">
              <div class="faq-answer-inner">
                {{ item.answer }}
              </div>
            </div>
          </li>
          {%- endfor %}
        </ul>
      </div>
    </div>

    <section class="cta-section">
      <div class="cta-inner">
        <h2>{{ t.cta_title }}</h2>
        <a href="/{{ L }}/contact.html" class="btn-book">
          <span>{{ t.cta_button }}</span>
          <span class="icon" aria-hidden="true"></span>
        </a>
      </div>
    </section>
