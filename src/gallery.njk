---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/gallery.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/gallery.css",
  navKey: "Gallery",
  extraFonts: "",
  currentPage: "gallery.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.ui[L]||data.ui.en).nav_gallery + " - Grant Consulting"; },
    description: function(data) { return (data.ui[data.lang.code]||data.ui.en).gallery_subtitle; },
    heroTitle: function(data) { return (data.ui[data.lang.code]||data.ui.en).nav_gallery; },
    breadcrumbs: function(data) { return [{ label: (data.ui[data.lang.code]||data.ui.en).nav_gallery }]; }
  }
}
