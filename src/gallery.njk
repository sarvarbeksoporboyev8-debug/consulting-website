    {# Lightbox #}
    <div class="gallery-lightbox" id="gallery-lightbox">
      <button class="gallery-lightbox-close" aria-label="Close">&times;</button>
      <button class="gallery-lightbox-prev" aria-label="Previous">&#8249;</button>
      <button class="gallery-lightbox-next" aria-label="Next">&#8250;</button>
      <div class="gallery-lightbox-content"></div>
    </div>

    <script>
    (function() {
      var items = document.querySelectorAll('[data-gallery]');
      var lightbox = document.getElementById('gallery-lightbox');
      var content = lightbox.querySelector('.gallery-lightbox-content');
      var closeBtn = lightbox.querySelector('.gallery-lightbox-close');
      var prevBtn = lightbox.querySelector('.gallery-lightbox-prev');
      var nextBtn = lightbox.querySelector('.gallery-lightbox-next');
      var current = 0;
      var total = items.length;

      function getSrc(item) {
        var vid = item.querySelector('video');
        if (vid) return { type: 'video', src: vid.src };
        var img = item.querySelector('img');
        return { type: 'img', src: img.src };
      }

      function show(index) {
        current = (index + total) % total;
        var data = getSrc(items[current]);
        if (data.type === 'video') {
          content.innerHTML = '<video src="' + data.src + '" controls autoplay style="max-width:90vw;max-height:85vh;border-radius:12px;"></video>';
        } else {
          content.innerHTML = '<img src="' + data.src + '" alt="Gallery" style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:12px;">';
        }
        lightbox.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }

      function close() {
        lightbox.classList.remove('is-open');
        content.innerHTML = '';
        document.body.style.overflow = '';
      }

      items.forEach(function(item, i) {
        item.addEventListener('click', function() { show(i); });
      });

      closeBtn.addEventListener('click', close);
      prevBtn.addEventListener('click', function() { show(current - 1); });
      nextBtn.addEventListener('click', function() { show(current + 1); });

      lightbox.addEventListener('click', function(e) {
        if (e.target === lightbox) close();
      });

      document.addEventListener('keydown', function(e) {
        if (!lightbox.classList.contains('is-open')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') show(current - 1);
        if (e.key === 'ArrowRight') show(current + 1);
      });
    })();
    </script>

