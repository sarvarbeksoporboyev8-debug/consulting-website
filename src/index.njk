---js
{
  pagination: {
    data: "languages",
    size: 1,
    alias: "lang"
  },
  permalink: function(data) {
    return data.lang.code + "/index.html";
  },
  layout: "layouts/base.njk",
  pageCss: "css/index.css",
  navKey: "Home",
  extraFonts: "",
  eleventyComputed: {
    title: function(data) {
      var L = data.lang.code;
      return "Grant Consulting - " + (data.ui[L] || data.ui.en).nav_home;
    },
    description: function(data) {
      var L = data.lang.code;
      return (data.site[L] || data.site.en).tagline;
    }
  }
}
---
    <section class="hero">
      <div class="hero-content">
        <h1>{{ t.hero_title | safe }}</h1>
        <p class="subtitle">{{ t.hero_subtitle }}</p>
        <div class="hero-buttons">
          <a href="/{{ L }}/contact.html#contact-form" class="btn-primary">{{ t.hero_cta_primary }}</a>
          <a href="/{{ L }}/about.html" class="hero-video">{{ t.hero_cta_secondary }}</a>
        </div>

        <div class="hero-social">
          <a href="{{ site.shared.instagram }}" class="hero-social-card hero-social-card--instagram" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="100">
            <svg class="hero-social-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            <span class="hero-social-platform">Instagram</span>
            <span class="hero-social-handle">@grant_consulting_</span>
            <span class="hero-social-cta">Follow us →</span>
          </a>
          <a href="{{ site.shared.telegram }}" class="hero-social-card hero-social-card--telegram" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="220">
            <svg class="hero-social-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            <span class="hero-social-platform">Telegram</span>
            <span class="hero-social-handle">@GrantConsulting</span>
            <span class="hero-social-cta">Join channel →</span>
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-image" style="background-image:url('{{ langRoot }}img/hero/hero.jpg');" aria-hidden="true"></div>
        <div class="hero-chart">
          <p class="hero-chart-title">{{ t.hero_chart_title }}</p>
          <hr>
          <div class="stat">
            <div class="stat-label">{{ t.hero_stat_countries }}</div>
            <div class="stat-value">12+</div>
          </div>
          <div class="stat">
            <div class="stat-label">{{ t.hero_stat_students }}</div>
            <div class="stat-value">500+</div>
          </div>
        </div>
      </div>
    </section>

    <section class="clients" data-aos="fade-up">
      <h2>{{ t.clients_title }}</h2>
      <div class="client-logos">
        {%- for uni in universities[L] %}
        {%- if loop.index <= 4 %}
        <img class="client-logo" src="{{ langRoot }}img/flags/{{ uni.flag }}" alt="{{ uni.country }}" title="{{ uni.country }}">
        {%- endif %}
        {%- endfor %}
      </div>
    </section>

    {% include "partials/features.njk" %}

    <section class="about">
      <div class="about-grid">
        <div data-aos="fade-right">
          <div class="about-badge">{{ t.about_badge }}</div>
          <h2>{{ t.about_title | safe }}</h2>
          <p class="about-desc">{{ t.about_desc }}</p>
          <div class="about-steps">
            {%- for step in steps[L] %}
            <div class="about-step" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}">
              <div class="about-step-num">{{ step.num }}</div>
              <div class="about-step-title">{{ step.title }}</div>
              <p class="about-step-desc">{{ step.description }}</p>
            </div>
            {%- endfor %}
          </div>
        </div>
        <div class="about-image" style="background-image:url('{{ langRoot }}img/about.jpg');" aria-hidden="true" data-aos="fade-left"></div>
      </div>
    </section>

    <section class="services">
      <div class="container">
        <div class="services-header" data-aos="fade-up">
          <h2>{{ t.services_title | safe }}</h2>
          <p>{{ t.services_subtitle }}</p>
        </div>
        <div class="services-grid">
          {%- for svc in services[L] | head(3) %}
          <div class="service-card" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 120 }}">
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.description }}</p>
            <a href="/{{ L }}/{{ svc.link }}" class="link">{{ t.btn_read_more }}<span class="sr-only"> {{ svc.title }}</span></a>
          </div>
          {%- endfor %}
        </div>
        <div class="services-cta-row">
          <div class="service-card service-card-cta" data-aos="zoom-in">
            <h3>{{ t.services_cta }}</h3>
            <a href="/{{ L }}/contact.html#contact-form" class="btn-primary">{{ t.btn_free_consultation }}</a>
          </div>
          {%- for svc in services[L] | slice(3, 4) %}
          <div class="service-card" data-aos="fade-up" data-aos-delay="120">
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.description }}</p>
            <a href="/{{ L }}/{{ svc.link }}" class="link">{{ t.btn_read_more }}<span class="sr-only"> {{ svc.title }}</span></a>
          </div>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="testimonials">
      <div class="section-header" data-aos="fade-up">
        <h2>{{ t.testimonials_title | safe }}</h2>
        <p>{{ t.testimonials_subtitle }}</p>
      </div>
      {% include "partials/testimonials-grid.njk" %}
    </section>

    <section class="blog">
      <div class="section-header" data-aos="fade-up">
        <h2>{{ t.blog_title | safe }}</h2>
        <p>{{ t.blog_subtitle }}</p>
      </div>
      <div class="blog-grid">
        {%- for post in blog[L] | head(2) %}
        <div class="blog-card" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 150 }}">
          <img class="image" src="{{ langRoot }}img/blog/{{ post.image }}" alt="{{ post.title }}">
          <div class="tag">{{ post.author }}-</div>
          <h3>{{ post.title }}</h3>
          <p>{{ post.excerpt }}</p>
        </div>
        {%- endfor %}
      </div>
    </section>

    {% set formPrefix = "home" %}
    {% include "partials/form-faq-section.njk" %}

    {% include "partials/cta-simple.njk" %}
