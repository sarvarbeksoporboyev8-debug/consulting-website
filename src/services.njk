---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/services.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/services.css",
  navKey: "Services",
  extraFonts: "&family=Merriweather:wght@700",
  currentPage: "services.html",
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.ui[L]||data.ui.en).page_services_title + " - Grant Consulting"; },
    description: function(data) { return (data.ui[data.lang.code]||data.ui.en).services_subtitle; },
    heroTitle: function(data) { return (data.ui[data.lang.code]||data.ui.en).page_services_hero; },
    breadcrumbs: function(data) { return [{ label: (data.ui[data.lang.code]||data.ui.en).page_services_hero }]; }
  }
}
---
    <section class="solution-section">
      <div class="solution-grid">
        <div class="solution-content">
          <h2>{{ t.services_solution_title }}</h2>
          <p class="intro">{{ t.services_solution_subtitle }}</p>
          <div class="solution-steps">
            {%- for step in steps[L] %}
            <div class="solution-step">
              <div class="solution-step-num">{{ step.num }}</div>
              <div class="solution-step-title">{{ step.title }}</div>
              <p class="solution-step-desc">{{ step.description }}</p>
            </div>
            {%- endfor %}
          </div>
        </div>
        <div class="solution-image" aria-hidden="true"></div>
      </div>
    </section>

    <section class="services-dark">
      <div class="container">
        <div class="services-header">
          <h2>{{ t.services_offer_title }}</h2>
          <p>{{ t.services_offer_subtitle }}</p>
        </div>
        <div class="services-grid">
          {%- for svc in services[L] | head(3) %}
          <div class="service-card" id="{{ svc.id }}">
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.description }}</p>
            <a href="/{{ L }}/{{ svc.link }}" class="btn-link">{{ t.btn_learn_more }}<span class="sr-only"> {{ svc.title }}</span></a>
          </div>
          {%- endfor %}
        </div>
        <div class="services-cta-row">
          <div class="service-card service-card-cta">
            <h3>{{ t.services_cta }}</h3>
            <a href="/{{ L }}/contact.html#contact-form" class="btn-primary">{{ t.btn_free_consultation }}</a>
          </div>
          {%- for svc in services[L] | slice(3) %}
          <div class="service-card" id="{{ svc.id }}">
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.description }}</p>
            <a href="/{{ L }}/{{ svc.link }}" class="btn-link">{{ t.btn_learn_more }}<span class="sr-only"> {{ svc.title }}</span></a>
          </div>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="testimonials">
      <div class="section-header">
        <h2>{{ t.testimonials_title | safe }}</h2>
        <p>{{ t.testimonials_subtitle }}</p>
      </div>
      {% include "partials/testimonials-grid.njk" %}
    </section>

    {% set formPrefix = "services" %}
    {% include "partials/form-faq-section.njk" %}

    {% include "partials/cta-simple.njk" %}
